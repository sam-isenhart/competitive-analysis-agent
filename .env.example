# ── Anthropic API ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Model Selection (optional overrides) ───────
# MODEL_FAST=claude-sonnet-4-5-20250929
# MODEL_QUALITY=claude-sonnet-4-5-20250929

# ── Competitor Research Config ─────────────────
COMPETITORS=Company1,Company2,Company3

# ── Notification Email ─────────────────────────
NOTIFY_EMAIL=you@example.com

# ── Web Search (optional; need one for live research) ─
# PERPLEXITY_API_KEY=pplx-...
# TAVILY_API_KEY=tvly-...

# ── News API (optional, fallback if no Tavily) ─
# NEWS_API_KEY=...

# ── Notion (optional) ─────────────────────────
# NOTION_API_KEY=secret_...
# NOTION_DATABASE_ID=...

# ── SMTP Email (optional) ─────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=you@gmail.com

# ── Postgres Checkpointer (optional) ──────────
POSTGRES_PASSWORD=langgraph

# ── LangSmith Observability (optional) ────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=competitive-intel
